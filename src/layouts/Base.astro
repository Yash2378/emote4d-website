---
import "@fontsource-variable/fraunces";
import "@fontsource/ibm-plex-sans/400.css";
import "@fontsource/ibm-plex-sans/500.css";
import "@fontsource/ibm-plex-sans/600.css";
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  /** Override the social share image (absolute path under /). */
  ogImage?: string;
}

const {
  title,
  description,
  ogImage = "/og-default.png",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://emote4d.com");
const ogUrl = new URL(ogImage, Astro.site ?? "https://emote4d.com");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical.href} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Reveal styles only apply when JS is present to trigger them -->
    <script is:inline>document.documentElement.classList.add("js");</script>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="EMOTE4D" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogUrl.href} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Quiet one-time reveal for sections marked data-rise.
      const els = document.querySelectorAll("[data-rise]");
      if (
        els.length &&
        !matchMedia("(prefers-reduced-motion: reduce)").matches
      ) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("risen");
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.1, rootMargin: "0px 0px -6% 0px" }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add("risen"));
      }
    </script>

    <style is:global>
      .skip-link {
        position: absolute;
        left: 0.5rem;
        top: 0.5rem;
        z-index: 100;
        background: var(--color-ink);
        color: var(--color-paper);
        padding: 0.6rem 1rem;
        border-radius: 6px;
        text-decoration: none;
        transform: translateY(-150%);
        transition: transform 0.15s ease;
      }
      .skip-link:focus {
        transform: translateY(0);
      }
      @media (prefers-reduced-motion: reduce) {
        .skip-link {
          transition: none;
        }
      }
    </style>
  </body>
</html>
