---
import Base from "../layouts/Base.astro";
import WaitlistCta from "../components/WaitlistCta.astro";

const designIntent = [
  {
    title: "Privacy that survives a procurement review",
    body: "Because no image is ever stored or transmitted, the answer to \"where does the footage go?\" is that there is none. The device produces a stick figure on-site and nothing else leaves the room. There's no facial recognition either &mdash; it reads posture, not identity. It's a shorter conversation with a privacy officer, and with residents' families.",
  },
  {
    title: "Designed against alert fatigue",
    body: "An alarm staff learn to ignore is worse than no alarm. EMOTE4D screens for a fall and then runs a separate check that the person is actually on the ground, with a short verification delay before anyone is notified. The discipline is deliberate: fewer, truer alerts.",
  },
  {
    title: "The safety function doesn't depend on the cloud",
    body: "Detection runs entirely on the device in the room. It keeps working through a Wi-Fi outage or an internet provider problem, because knowing a fall happened never required a round-trip to a server in the first place.",
  },
];
---

<Base
  title="EMOTE4D for care facilities — fall coverage that passes a privacy review"
  description="Camera-based fall detection for care facilities: no image stored or transmitted, designed against alert fatigue, and built so the core safety function never depends on the cloud. Seeking pilot partners in Manitoba for 2026."
>
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">For care facilities</p>
      <h1>Fall coverage that passes a privacy review.</h1>
      <p class="page-lead">
        Cameras in resident rooms are usually a non-starter &mdash; for good
        reason. EMOTE4D is the version operators can actually defend: a sensor
        that never keeps an image, is built to avoid the false alarms that erode
        staff trust, and keeps working when the network doesn't.
      </p>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-primary">Talk to us about a pilot</a>
        <a href="/technology" class="btn btn-ghost">Read the architecture</a>
      </div>
    </div>
  </section>

  <!-- Three design intents -->
  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Why it's built this way</p>
      <h2>Three problems an operator actually has.</h2>
      <div class="intent-list">
        {
          designIntent.map((d) => (
            <article class="intent">
              <h3>{d.title}</h3>
              <p>{d.body}</p>
            </article>
          ))
        }
      </div>
      <p class="note">
        These are design intentions for the pilot, not validated results. We'll
        have honest numbers to share once the pilot has produced them.
      </p>
    </div>
  </section>

  <!-- What a pilot looks like -->
  <section class="section panel">
    <div class="wrap">
      <p class="eyebrow">The pilot</p>
      <h2>What a pilot looks like.</h2>
      <div class="prose">
        <p class="lead">
          We're looking for a small number of care settings in Manitoba to run
          EMOTE4D in real rooms, in 2026, and to tell us the truth about it.
        </p>
        <p>
          A pilot means installing the device in a set of rooms, routing
          confirmed-fall alerts to the staff or workflow you choose, and sitting
          down with us regularly to review what fired, what didn't, and what
          needs to change. The point of a pilot is to find the gaps before anyone
          relies on it &mdash; so we'd rather hear what's wrong than what's
          polite.
        </p>
      </div>
    </div>
  </section>

  <WaitlistCta
    eyebrow="Pilot partners"
    title="Explore a pilot with us."
    body="Tell us about your facility and what you're trying to cover. We're prioritizing partners in Manitoba for the 2026 pilot."
    cta="Talk to us about a pilot"
  />
</Base>

<style>
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }
  .section h2 {
    font-size: var(--text-3xl);
    margin: 0.75rem 0 0;
    max-width: 24ch;
  }
  .panel {
    background: var(--color-pine-wash);
  }

  .intent-list {
    margin-top: 2.5rem;
    border-top: 1px solid var(--color-line);
  }
  .intent {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--color-line-soft);
  }
  .intent h3 {
    font-size: var(--text-xl);
    margin: 0 0 0.5rem;
  }
  .intent p {
    color: var(--color-muted);
    max-width: 52rem;
    margin: 0;
  }
  .note {
    margin-top: 1.75rem;
    max-width: 44rem;
    font-size: var(--text-sm);
    color: var(--color-faint);
  }
  .prose {
    margin-top: 2rem;
  }

  @media (min-width: 880px) {
    .intent {
      display: grid;
      grid-template-columns: 18rem 1fr;
      gap: 2.5rem;
      align-items: start;
    }
    .intent h3 {
      margin: 0;
    }
  }
</style>
